### Redis + Celery (What to Add)
```python
# backend/tasks/pipeline_task.py (NEW FILE)
from celery import Celery
app = Celery('tasks', broker='redis://localhost:6379/0',
             backend='redis://localhost:6379/0')

@app.task(bind=True, max_retries=3)
def run_pipeline_task(self, dataset_id: str):
    stages = [
        ('cleaning', 12), ('schema', 25), ('kpi', 45),
        ('visualization', 65), ('insights', 80), ('eval', 95)
    ]
    for status, progress in stages:
        update_status(dataset_id, status, progress)
        # run agent ...
    update_status(dataset_id, 'complete', 100)

# Frontend: EventSource('/api/pipeline/status/{id}') → progress bar
```

### Conversation Agent (6-Turn Memory)
```python
# backend/agents/conversation_agent.py (NEW FILE)
MAX_HISTORY = 6

async def converse(query: str, dataset_id: str, schema: dict, history: list) -> dict:
    context = retrieve_context(query, dataset_id)  # RAG
    messages = [{"role":"system","content": f"Schema: {schema}\nContext: {context}"}]
    messages += history[-MAX_HISTORY:]  # sliding window
    messages.append({"role":"user","content": query})
    response = await call_llm(messages)
    return {"answer": response, "history": history + [
        {"role":"user","content": query},
        {"role":"assistant","content": response}
    ]}
```

