# Talking BI Environment Variables
# Copy this file to .env and fill in your actual values

# =============================================================================
# API Keys
# =============================================================================
# Get your free Groq API key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# =============================================================================
# Backend Configuration
# =============================================================================
DATA_DIR=./data
MAX_FILE_SIZE_MB=100
SQLITE_DB_PATH=./data/talking_bi.db

# =============================================================================
# Redis Configuration
# =============================================================================
# For Docker: use redis://redis:6379/0
# For local: use redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# CORS Configuration
# =============================================================================
# Add your frontend URLs here (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80

# =============================================================================
# Celery Configuration (Background Tasks)
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =============================================================================
# AWS Configuration (Optional)
# =============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# =============================================================================
# Ollama Configuration (Local LLM for Privacy Mode)
# =============================================================================
# For Docker: use http://host.docker.internal:11434
# For local: use http://localhost:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama2
LLM_PROVIDER=auto

# =============================================================================
# Email Configuration (for Morning Briefings)
# =============================================================================
# Gmail: Use App Password (not your regular password)
# Get App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=your_email@gmail.com